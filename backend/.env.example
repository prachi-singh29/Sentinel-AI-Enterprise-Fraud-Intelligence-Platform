# PostgreSQL connection string (Railway/Render provide this automatically as DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frauddb

# JWT
SECRET_KEY=replace-with-a-long-random-string
ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# Default admin account created on first boot
ADMIN_EMAIL=admin@frauddetect.io
ADMIN_PASSWORD=Admin123!
